# ─── Supabase (optional — only needed for Cloud mode) ─────────────────────
# Lite runs in Local mode by default and uses ~/.tradedashboard/local.db.
# These vars are only read when you flip the toggle to Cloud in /settings.
#
# Create a free project at https://supabase.com/dashboard and copy these
# from Project Settings → API. After pasting, run both SQL files from
# supabase/migrations/ in the SQL Editor before flipping the toggle.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── NinjaTrader LiveBridge (optional, Cloud mode only) ──────────────────
# In Local mode, NT8 talks to the dashboard over plain HTTP — set the URL
# in /settings instead. These WebSocket vars are only used in Cloud mode.
#
# Examples:
#   ws://127.0.0.1:8765        — same machine as the dashboard
#   ws://192.168.1.50:8765     — separate Windows box on your LAN
NEXT_PUBLIC_LIVEBRIDGE_WS_URL=
LIVEBRIDGE_WS_URL=

# Local listen port for the ws-proxy that fronts LiveBridge.
# Defaults to 8766. Override only if 8766 is taken.
# WS_PROXY_PORT=8766

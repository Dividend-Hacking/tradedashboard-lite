# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# embedded terminal — random per-startup secret used to authorize the
# xterm.js drawer's WebSocket connection (see scripts/term-server.mjs).
# Must NEVER be committed; regenerated automatically on each `npm run dev`.
.terminal-token

# Per-run dashboard backtest snapshots written by /api/scripts/results.
# Generated locally for Claude Code analysis — not part of the codebase.
/backtests/dashboard-results/*
!/backtests/dashboard-results/.gitkeep
